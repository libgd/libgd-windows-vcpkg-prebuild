        "libheif",
        "libjpeg-turbo",
        "liblzma",
        "libpng",
        "libyuv",
        "libwebp",
        "tiff",
        "x265",
        "zlib",
        "libiconv",
        "freetype",
        "exiv2",
        "aom",
        "dav1d"
      ],
      "customBuilds": [
        {
          "name": "libavif",
          "sourceUrl": "https://github.com/AOMediaCodec/libavif/archive/refs/tags/v1.4.2.zip",
          "buildType": "Release",
          "cmakeOptions": [
            "CMAKE_C_COMPILER=cl",
            "CMAAKE_CXX_COMPILER=cl",
            "CMAKE_BUILD_TYPE=${{env.BUILD_TYPE}}",
            "AVIF_CODEC_AOM=SYSTEM",
            "AVIF_CODEC_DAV1D=SYSTEM",
            "BUILD_SHARED_LIBS=ON",
            "AVIF_BUILD_APPS=OFF",
            "AVIF_BUILD_TESTS=OFF"
          ],
          "requiredFiles": [
            "include/avif/avif.h",
