{
  "vcpkgExecutable": "C:\\vcpkg\\vcpkg.exe",
  "archives": [
    {
      "archiveName": "x64-windows.7z",
      "triplet": "x64-windows",
      "packages": [
        "brotli",
        "bzip2",
        "freetype",
        "libde265",
        "libheif",
        "libjpeg-turbo",
        "liblzma",
        "libpng",
        "libyuv",
        "libwebp",
        "tiff",
        "x265",
        "zlib",
        "libiconv",
        "freetype",
        "exiv2",
        "aom",
        "dav1d"
      ],
      "customBuilds": [
        {
          "name": "libavif",
          "sourceUrl": "https://github.com/AOMediaCodec/libavif/archive/refs/tags/v1.4.2.zip",
          "buildType": "Release",
          "cmakeOptions": [
            "CMAKE_C_COMPILER=cl",
            "CMAAKE_CXX_COMPILER=cl",
            "CMAKE_BUILD_TYPE=${{env.BUILD_TYPE}}",
            "AVIF_CODEC_AOM=SYSTEM",
            "AVIF_CODEC_DAV1D=SYSTEM",
            "BUILD_SHARED_LIBS=ON",
            "AVIF_BUILD_APPS=OFF",
            "AVIF_BUILD_TESTS=OFF"
          ],
          "requiredFiles": [
            "include/avif/avif.h",
            "lib/avif.lib",
            "lib/cmake/libavif/libavif-config.cmake"
          ],
          "copyDirectories": [
            {
              "source": "lib/cmake/libavif",
              "destination": "share/libavif"
            }
          ]
        }
      ]
    },
    {
      "archiveName": "x86-windows.7z",
      "triplet": "x86-windows",
      "packages": [
        "brotli",
        "bzip2",
        "freetype",
        "libde265",
        "libheif",
        "libjpeg-turbo",
        "liblzma",
        "libpng",
        "libwebp",
        "tiff",
        "zlib",
        "libiconv",
        "freetype"
      ]
    },
    {
      "archiveName": "amd64_arm64-windows.7z",
      "triplet": "arm64-windows",
      "packages": [
        "brotli",
